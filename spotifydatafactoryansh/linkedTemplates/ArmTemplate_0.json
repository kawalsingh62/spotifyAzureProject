											"parameters": {
												"json_directory": "bronze",
												"json_folder": {
													"value": "@{item().table}_cdc",
													"type": "Expression"
												},
												"json_file": "cdc.json"
											}
										},
										"firstRowOnly": false
									}
								},
								{
									"name": "current_date",
									"type": "SetVariable",
									"dependsOn": [],
