									"dependsOn": [
										{
											"activity": "cp_db_to_adls",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"userProperties": [],
									"typeProperties": {
										"expression": {
											"value": "@greater(activity('cp_db_to_adls').output.dataRead,0 )",
											"type": "Expression"
										},
										"ifFalseActivities": [
											{
												"name": "Delete1",
												"type": "Delete",
												"dependsOn": [],
												"policy": {
													"timeout": "0.12:00:00",
													"retry": 0,
													"retryIntervalInSeconds": 30,
													"secureOutput": false,
													"secureInput": false
												},
												"userProperties": [],
												"typeProperties": {
													"dataset": {
														"referenceName": "ds_adls_parquet",
														"type": "DatasetReference",
														"parameters": {
															"Pqt_directory": "bronze",
															"pqt_folder": {
																"value": "@item().table",
																"type": "Expression"
															},
															"pqt_file": "@concat(item().schema,'.',item().table,'_',variables('curretn_date'))"
														}
													},
													"enableLogging": false,
													"storeSettings": {
														"type": "AzureBlobFSReadSettings",
														"recursive": true,
														"enablePartitionDiscovery": false
													}
												}
											}
										],
										"ifTrueActivities": [
											{
												"name": "lastDate",
												"type": "Script",
