													"value": "@item().table",
													"type": "Expression"
												},
												"pqt_file": {
													"value": "@concat(item().schema,'.',item().table,'_',variables('curretn_date'))",
													"type": "Expression"
												}
											}
										}
									]
								},
								{
									"name": "Lookup_json",
									"type": "Lookup",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
